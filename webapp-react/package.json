    "@telegram-apps/telegram-ui": "^2.1.13",
    "@tma.js/sdk-react": "^3.0.22",
    "chord-transposer": "^3.0.9",
    "eruda": "^3.4.3",
    "i18next": "^26.3.2",
    "notiflix": "^3.2.8",
    "react": "^19.2.7",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
